<div class="post">
    <h2><%= @post.title %></h2>
    <p><%= @post.body %></p>
    <p>Posted by: <%= link_to @post.user.email, user_path(@post.user) %></p>

    <h3>Comments</h3>

    <% @post.comments.each do |comment| %>
        <%= render partial: "comments/comment", locals: { comment: comment, post: @post } %>
    <% end %>


    <% if user_signed_in? %>
        <%= form_with model: [@post, Comment.new] do |f| %>
            <%= f.text_area :body %>
            <%= f.submit "Comment" %>
        <% end %>
    <% else %>
        <p>You must be logged in to comment</p>
    <% end %>

    <% if owner?(@post) %>
        <%= button_to "Delete Post",
            post_path(@post),
            method: :delete,
            data: { confirm: "Are you sure?" } %>
    <% end %>

<%= link_to "Back", user_path(@post.user), class: "btn btn-secondary" %>