<div style="padding:10px; background:#eee;">
  <% if user_signed_in? %>
    Logged in as: <strong><%= current_user.email %></strong>

    <%= link_to "My Profile", user_path(current_user) %>

    <%= button_to "Log out",
        destroy_user_session_path,
        method: :delete %>
  <% else %>
    <p>Not logged in</p>

    <%= link_to "Log in", new_user_session_path %>
  <% end %>
</div>