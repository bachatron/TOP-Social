<%= render "shared/errors", object: @post %>

<% if user_signed_in? && current_user == user %>
  <%= form_with model: @post do |f| %>
    <%= f.text_field :title, placeholder: "Title" %>
    <%= f.text_area :body, placeholder: "Write something..." %>
    <%= f.submit "Create Post" %>
  <% end %>
<% end %>